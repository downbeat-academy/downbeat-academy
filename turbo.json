{
	"$schema": "https://turborepo.org/schema.json",
	"pipeline": {
		"build": {
			"outputs": [".next", "dist", "public"]
		},
		"dev": {
			"cache": false
		},
		"test": {
			"dependsOn": ["build"]
		},
		"lint": {
			"outputs": []
		},
		"deploy": {
			"dependsOn": ["build", "test", "lint"]
		}
	}
}
