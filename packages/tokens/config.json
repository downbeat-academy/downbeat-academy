{
	"source": ["src/**/*.json"],
	"platforms": {
		"scss": {
			"transformGroup": "scss",
			"buildPath": "dist/",
			"files": [
				{
					"destination": "tokens.scss",
					"format": "scss/variables"
				},
				{
					"destination": "tokens.css",
					"format": "css/variables"
				}
			]
		},
		"json": {
			"buildPath": "dist/",
			"files": [
				{
					"destination": "tokens.json",
					"format": "json"
				}
			]
		}
	}
}
