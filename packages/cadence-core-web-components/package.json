{
  "name": "cadence-core-web-components",
  "version": "0.2.0",
  "author": "Jory Tindall <jory@downbeatacademy.com>",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "serve storybook-static -l tcp://0.0.0.0:$PORT",
    "clean": "rm -rf dist",
    "build": "pnpm run clean && vite build && tsc --emitDeclarationOnly --outDir dist",
    "storybook": "storybook dev -p 6007 --ci",
    "build:storybook": "storybook build",
    "test": "vitest"
  },
  "dependencies": {
    "cadence-tokens": "workspace:^",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/web-components": "^10.3.6",
    "@storybook/web-components-vite": "^10.3.6",
    "serve": "^14.2.6",
    "storybook": "^10.3.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    }
  }
}
