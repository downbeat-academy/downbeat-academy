# Database (shared with www auth tables on Neon)
DATABASE_URL_AUTH=postgresql://...

# Auth Configuration
BETTER_AUTH_SECRET=your-secret-key
AUTH_SERVICE_URL=https://auth.downbeatacademy.services
NEXT_PUBLIC_AUTH_SERVICE_URL=https://auth.downbeatacademy.services

# Default redirect (when no redirect_uri provided)
DEFAULT_REDIRECT_URL=https://downbeatacademy.com

# Email
RESEND_API_KEY=your-resend-api-key
RESEND_DEFAULT_AUDIENCE_ID=your-audience-id

# CORS - additional allowed origins (comma-separated, for preview deployments)
# ALLOWED_ORIGINS=https://www-preview-abc.up.railway.app,https://links-preview-abc.up.railway.app

# Environment
NODE_ENV=development
