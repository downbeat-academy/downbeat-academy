{
	"name": "auth",
	"version": "1.0.1",
	"private": true,
	"description": "Centralized authentication service for Downbeat Academy",
	"author": "Jory Tindall <jory@downbeatacademy.com>",
	"license": "UNLICENSED",
	"scripts": {
		"dev": "infisical run --env=dev --path=/auth -- next dev --port 3002",
		"dev:ci": "next dev --port 3002",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"db:push": "drizzle-kit push --config=drizzle-auth.config.ts",
		"db:migrate": "drizzle-kit migrate --config=drizzle-auth.config.ts",
		"db:verify-roles": "npx tsx scripts/verify-user-roles.ts",
		"db:fix-roles": "npx tsx scripts/verify-user-roles.ts --fix"
	},
	"dependencies": {
		"@better-auth/oauth-provider": "^1.6.10",
		"@hookform/resolvers": "^5.2.2",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toast": "^1.2.15",
		"auth-permissions": "workspace:^",
		"better-auth": "^1.6.10",
		"cadence-core": "workspace:^",
		"cadence-icons": "workspace:^",
		"cadence-tokens": "workspace:^",
		"classnames": "^2.5.1",
		"drizzle-orm": "^0.45.2",
		"email": "workspace:^",
		"next": "^16.2.6",
		"pg": "^8.20.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-hook-form": "^7.75.0",
		"resend": "^6.12.3",
		"typeface-favorit": "workspace:^",
		"typeface-tiempos-text": "workspace:^",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.6.2",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.1.6",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.2",
		"eslint-config-next": "^16.2.6",
		"typescript": "^5.9.3"
	}
}