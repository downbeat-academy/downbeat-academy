# Application
NEXT_PUBLIC_APP_URL=https://links.downbeatacademy.services

# Auth Service
AUTH_SERVICE_URL=https://auth.downbeatacademy.services
BETTER_AUTH_SECRET=your-secret-key

# OAuth Client (registered with the auth service)
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Database - Auth (shared, for session validation)
DATABASE_URL_AUTH=postgresql://...

# Database - Links
DATABASE_PUBLIC_URL=postgresql://...

# Environment
NODE_ENV=development
