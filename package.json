{
	"name": "@downbeat-academy/cadence",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run text",
		"lint": "turbo run lint",
		"prettier": "prettier --write .",
		"dev": "turbo run dev",
		"core:dev": "yarn workspace @downbeat-academy/cadence-core dev",
		"core:build": "yarn workspace @downbeat-academy/cadence-core build",
		"tokens:build": "yarn workspace @downbeat-academy/cadence-tokens build",
		"docs:dev": "yarn workspace @downbeat-academy/cadence-docs dev",
		"www:dev": "yarn workspace @downbeat-academy/www dev",
		"www:build": "yarn workspace @downbeat-academy/www build",
		"cms:dev": "yarn workspace @downbeat-academy/sanity-cms sanity start",
		"cms:build": "yarn workspace @downbeat-academy/sanity-cms sanity build"
	},
	"devDependencies": {
		"concurrently": "^7.2.2",
		"prettier": "^2.7.1",
		"turbo": "^1.3.1"
	},
	"dependencies": {
		"@changesets/cli": "^2.25.0",
		"@types/prettier": "2.6.0"
	}
}
