{
	"name": "@downbeat-academy/cadence",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run text",
		"lint": "turbo run lint",
		"dev-all": "concurrently \"yarn dev-cms\" \"yarn dev-web\" \"yarn dev-ds\"",
		"format-all": "prettier --write .",
		"dev": "turbo run dev",
		"dev-stencil": "yarn workspace @downbeat-academy/web-components start",
		"build-tokens": "yarn workspace @downbeat-academy/tokens build"
	},
	"devDependencies": {
		"concurrently": "^7.2.2",
		"prettier": "^2.7.1",
		"turbo": "^1.3.1"
	}
}
